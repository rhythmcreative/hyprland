#!/bin/bash
# Helper script for SDDM operations requiring root privileges
# This script is intended to be run via sudo without password (configured in sudoers)

set -e

SDDM_THEME_DIR="/usr/share/sddm/themes/sddm-astronaut-theme"
BACKGROUNDS_DIR="$SDDM_THEME_DIR/Backgrounds"
# Archivos de configuración conocidos (algunas instalaciones usan uno u otro)
THEME_CONFIG_ROOT="$SDDM_THEME_DIR/theme.conf"
THEME_CONFIG_SUB="$SDDM_THEME_DIR/Themes/theme1.conf"

update_config_value() {
    local key="$1"
    local value="$2"
    local file="$3"
    if [ -f "$file" ]; then
        # Manejar diferentes formatos de comillas
        if grep -q "^$key=" "$file"; then
            sed -i "s|^$key=.*|$key=$value|" "$file"
        fi
    fi
}

case "$1" in
    "update-wallpaper")
        SOURCE_FILE="$2"
        if [ -f "$SOURCE_FILE" ]; then
            cp "$SOURCE_FILE" "$BACKGROUNDS_DIR/current_wallpaper.jpg"
            update_config_value "Background" "\"Backgrounds/current_wallpaper.jpg\"" "$THEME_CONFIG_ROOT"
            update_config_value "Background" "\"Backgrounds/current_wallpaper.jpg\"" "$THEME_CONFIG_SUB"
            echo "✅ Wallpaper updated in SDDM theme (root and sub-theme)"
        else
            echo "❌ Source file not found: $SOURCE_FILE"
            exit 1
        fi
        ;;
    "update-theme-colors")
        SOURCE_CONFIG="$2"
        if [ -f "$SOURCE_CONFIG" ]; then
            # Si pasamos un archivo completo, lo copiamos a ambos sitios
            [ -f "$THEME_CONFIG_ROOT" ] && cp "$SOURCE_CONFIG" "$THEME_CONFIG_ROOT"
            [ -f "$THEME_CONFIG_SUB" ] && cp "$SOURCE_CONFIG" "$THEME_CONFIG_SUB"
            echo "✅ SDDM theme colors updated in both config files"
        else
            echo "❌ Source config not found: $SOURCE_CONFIG"
            exit 1
        fi
        ;;
    "update-cursor")
        CURSOR_THEME="$2"
        CURSOR_SIZE="$3"
        if [ -n "$CURSOR_THEME" ] && [ -n "$CURSOR_SIZE" ]; then
            # Crear directorio de configuración si no existe
            mkdir -p /etc/sddm.conf.d
            
            # Actualizar o crear archivo de configuración del cursor
            cat > /etc/sddm.conf.d/cursor.conf <<EOF
[Theme]
CursorTheme=$CURSOR_THEME
CursorSize=$CURSOR_SIZE
EOF
            
            update_config_value "CursorTheme" "$CURSOR_THEME" "$THEME_CONFIG_ROOT"
            update_config_value "CursorTheme" "$CURSOR_THEME" "$THEME_CONFIG_SUB"
            
            echo "✅ Cursor updated to $CURSOR_THEME ($CURSOR_SIZE)"
        else
            echo "❌ Missing cursor arguments"
            exit 1
        fi
        ;;
    "update-monitors")
        SOURCE_XSETUP="$2"
        if [ -f "$SOURCE_XSETUP" ]; then
            mkdir -p "/etc/sddm"
            cp "$SOURCE_XSETUP" "/etc/sddm/Xsetup"
            chmod +x "/etc/sddm/Xsetup"
            echo "✅ SDDM Xsetup updated"
        else
            echo "❌ Source Xsetup not found: $SOURCE_XSETUP"
            exit 1
        fi
        ;;
    "restart-sddm")
        systemctl restart sddm
        echo "✅ SDDM restarted"
        ;;
    *)
        echo "❌ Unknown command: $1"
        exit 1
        ;;
esac
