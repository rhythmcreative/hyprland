#!/bin/bash

# Script para sincronizar el wallpaper de SDDM con el wallpaper actual del usuario
# Autor: rhythmcreative
# Fecha: $(date '+%Y-%m-%d')

# Determinar el HOME del usuario real (no root)
if [[ $(id -u) -eq 0 ]] && [[ -n "$SUDO_USER" ]]; then
    REAL_USER="$SUDO_USER"
    REAL_HOME=$(getent passwd "$SUDO_USER" | cut -d: -f6)
else
    REAL_USER="$USER"
    REAL_HOME="$HOME"
fi

LOG_FILE="/tmp/sddm-wallpaper-sync.log"
CURRENT_WALLPAPER_FILE="$REAL_HOME/.cache/current-wallpaper"
USER_HOME="$REAL_HOME"
SDDM_THEME_DIR="/usr/share/sddm/themes/sddm-astronaut-theme"
SDDM_WALLPAPER_DIR="/usr/share/sddm/themes/sddm-astronaut-theme/Backgrounds"

# Función de logging
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
}

# Verificar si tenemos permisos de administrador
if [[ $EUID -ne 0 ]]; then
    log "ERROR: Este script debe ejecutarse con permisos de root"
    notify-send "SDDM Wallpaper Sync" "Error: Se requieren permisos de administrador"
    exit 1
fi

log "Iniciando sincronización de wallpaper de SDDM"

# Verificar que existe el archivo de wallpaper actual
if [[ ! -f "$CURRENT_WALLPAPER_FILE" ]]; then
    log "ERROR: No se encontró el archivo de wallpaper actual: $CURRENT_WALLPAPER_FILE"
    exit 1
fi

# Leer la ruta del wallpaper actual
WALLPAPER_PATH=$(cat "$CURRENT_WALLPAPER_FILE")

# Verificar que el archivo de wallpaper existe
if [[ ! -f "$WALLPAPER_PATH" ]]; then
    log "ERROR: El archivo de wallpaper no existe: $WALLPAPER_PATH"
    exit 1
fi

log "Wallpaper actual detectado: $WALLPAPER_PATH"

# Crear directorio de backgrounds si no existe
mkdir -p "$SDDM_WALLPAPER_DIR"

# Obtener la extensión del archivo
EXTENSION="${WALLPAPER_PATH##*.}"
EXTENSION_LOWER="${EXTENSION,,}"

# Nombre del archivo de destino
DEST_FILE="$SDDM_WALLPAPER_DIR/current_wallpaper.jpg"

# Para imágenes o GIFs, convertir/copiar a JPG que es lo que espera el tema
log "Procesando imagen para SDDM"
magick "$WALLPAPER_PATH[0]" -quality 95 "$DEST_FILE" 2>/dev/null

if [[ $? -ne 0 ]]; then
    log "Magick falló, intentando copia directa"
    cp "$WALLPAPER_PATH" "$DEST_FILE" 2>/dev/null
fi

# Cambiar permisos del archivo
chmod 644 "$DEST_FILE"

# Configuración del tema
THEME_CONF="$SDDM_THEME_DIR/Themes/theme1.conf"

if [[ ! -f "$THEME_CONF" ]]; then
    log "ERROR: No se encontró el archivo de configuración del tema: $THEME_CONF"
    exit 1
fi

# Actualizar las rutas del background en la configuración
sed -i "s|^Background=.*|Background=\"Backgrounds/current_wallpaper.jpg\"|" "$THEME_CONF"
log "Configuración de background actualizada en theme1.conf"

# Si tenemos colores de pywal del usuario, aplicarlos
USER_PYWAL_COLORS="$REAL_HOME/.cache/wal/colors"
if [[ -f "$USER_PYWAL_COLORS" ]]; then
    log "Aplicando colores de pywal del usuario a SDDM"
    
    # Leer colores de pywal
    COLOR0=$(sed -n '1p' "$USER_PYWAL_COLORS")  # background
    COLOR1=$(sed -n '2p' "$USER_PYWAL_COLORS")  # color1
    COLOR4=$(sed -n '5p' "$USER_PYWAL_COLORS")  # color4 (Highlight)
    COLOR7=$(sed -n '8p' "$USER_PYWAL_COLORS")  # foreground
    COLOR8=$(sed -n '9p' "$USER_PYWAL_COLORS")  # color8 (Placeholder)
    
    # Actualizar colores en la configuración del tema Astronaut
    sed -i "s|^HighlightColor=.*|HighlightColor=\"$COLOR4\"|" "$THEME_CONF"
    sed -i "s|^BackgroundColor=.*|BackgroundColor=\"$COLOR0\"|" "$THEME_CONF"
    sed -i "s|^TextColor=.*|TextColor=\"$COLOR7\"|" "$THEME_CONF"
    sed -i "s|^PlaceholderColor=.*|PlaceholderColor=\"$COLOR8\"|" "$THEME_CONF"
    sed -i "s|^SystemButtonsIconColor=.*|SystemButtonsIconColor=\"$COLOR1\"|" "$THEME_CONF"
    
    log "Colores de pywal aplicados a la configuración de SDDM"
else
    log "WARNING: No se encontraron colores de pywal del usuario"
fi

log "Configuración del tema SDDM actualizada"

log "Sincronización de wallpaper de SDDM completada exitosamente"

# Si se ejecuta desde un entorno gráfico, mostrar notificación
if [[ -n "$DISPLAY" ]] || [[ -n "$WAYLAND_DISPLAY" ]]; then
    # Ejecutar como el usuario correcto para la notificación
    sudo -u "$REAL_USER" DISPLAY="$DISPLAY" WAYLAND_DISPLAY="$WAYLAND_DISPLAY" notify-send "SDDM Wallpaper" "Wallpaper sincronizado con SDDM" 2>/dev/null || true
fi

exit 0
