#!/bin/bash

# ═══════════════════════════════════════════════════════════════════════════════
# 🚀 WALLPAPER LOADER - ULTRA FAST VERSION 🚀
# ═══════════════════════════════════════════════════════════════════════════════
# Optimizado para inicio ultra rápido de Hyprland

LOG_FILE="$HOME/.cache/wallpaper-theme.log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
}

# Verificación de daemon (soporta awww)
DAEMON_RUNNING=false
if pgrep -x "awww-daemon" > /dev/null; then
    DAEMON_RUNNING=true
fi

if [ "$DAEMON_RUNNING" = false ]; then
    log "🔧 Daemon no detectado, intentando iniciar awww-daemon..."
    # Usar setsid para que el daemon no muera con el script
    setsid awww-daemon --format xrgb --no-cache > /dev/null 2>&1 &

    # Esperar a que el daemon esté listo
    for i in {1..50}; do
        if awww query > /dev/null 2>&1; then
            log "✅ Daemon listo tras $((i*100))ms"
            DAEMON_RUNNING=true
            break
        fi
        sleep 0.1
    done
fi

if [ "$DAEMON_RUNNING" = false ]; then
    log "❌ Error: No se pudo iniciar el daemon de wallpaper"
    exit 1
fi

# Carga del wallpaper desde el registro de cache
CACHE_FILE="$HOME/.cache/current-wallpaper"
SDDM_WP="/usr/share/sddm/themes/sddm-astronaut-theme/Backgrounds/current_wallpaper.jpg"

if [[ -f "$CACHE_FILE" ]]; then
    WALLPAPER_PATH=$(cat "$CACHE_FILE")

    if [[ -f "$WALLPAPER_PATH" ]]; then
        log "⚡ Cargando wallpaper actual: $(basename "$WALLPAPER_PATH")"
        awww img "$WALLPAPER_PATH" --transition-type grow --transition-pos center --transition-duration 1.5 --transition-fps 60 > /dev/null 2>&1 || true
    else
        log "⚠️ Wallpaper en cache no existe: $WALLPAPER_PATH"
    fi
elif [[ -f "$HOME/.cache/wal/wal" ]]; then
    FALLBACK=$(cat "$HOME/.cache/wal/wal")
    log "⚡ Usando fallback de pywal: $(basename "$FALLBACK")"
    awww img "$FALLBACK" --transition-type grow --transition-pos center --transition-duration 1.5 --transition-fps 60 > /dev/null 2>&1 || true
elif [[ -f "$SDDM_WP" ]]; then
    log "⚡ Sincronizando con wallpaper de SDDM..."
    awww img "$SDDM_WP" --transition-type grow --transition-pos center --transition-duration 1.5 --transition-fps 60 > /dev/null 2>&1 || true
    # Opcional: registrarlo como actual para pywal
    echo "$SDDM_WP" > "$CACHE_FILE"
fi

log "✅ Proceso de carga completado"
