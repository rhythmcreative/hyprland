#!/bin/bash

# sync-nm-applet-colors: Version ULTRA-FINAL
# Deja de usar imports y escribe directamente en los archivos de tema para asegurar prioridad

echo "🎨 Sincronizando nm-applet (Fuerza Bruta)..."

WAL_COLORS="$HOME/.cache/wal/colors"
[ -f "$WAL_COLORS" ] || { echo "❌ No hay colores"; exit 1; }

# Leer colores
BG=$(sed -n '1p' "$WAL_COLORS")
FG=$(sed -n '8p' "$WAL_COLORS")
ACCENT=$(sed -n '5p' "$WAL_COLORS")
HOVER=$(sed -n '9p' "$WAL_COLORS")

# Definir bloque de estilos (usando selectores de maxima prioridad)
STYLE_BLOCK="
/* --- NM-APPLET DYNAMIC SYNC --- */
menu, .menu, menuitem, .menuitem, #nm-applet-menu, .nm-applet-menu {
    background-color: $BG !important;
    color: $FG !important;
}
menuitem:hover, .menuitem:hover, menuitem:selected, .menuitem:selected {
    background-color: $ACCENT !important;
    color: $BG !important;
}
#nm-applet-menu menuitem:hover {
    background-color: $ACCENT !important;
    color: $BG !important;
}
window.popup, .background.popup, popover.background {
    background-color: $BG !important;
}
/* --- END NM-APPLET DYNAMIC SYNC --- */
"

# 1. Limpiar y Aplicar a .config (GTK 3 y 4)
for CSS in "$HOME/.config/gtk-3.0/gtk.css" "$HOME/.config/gtk-4.0/gtk.css"; do
    [ -f "$CSS" ] || touch "$CSS"
    sed -i '/NM-APPLET DYNAMIC SYNC/,/END NM-APPLET DYNAMIC SYNC/d' "$CSS"
    echo "$STYLE_BLOCK" >> "$CSS"
done

# 2. Limpiar y Aplicar directamente al TEMA (GTK 3 y 4)
THEME_BASE="$HOME/.themes/PywalSync-Mono"
if [ -d "$THEME_BASE" ]; then
    for CSS in "$THEME_BASE/gtk-3.0/gtk.css" "$THEME_BASE/gtk-4.0/gtk.css"; do
        if [ -f "$CSS" ]; then
            sed -i '/NM-APPLET DYNAMIC SYNC/,/END NM-APPLET DYNAMIC SYNC/d' "$CSS"
            echo "$STYLE_BLOCK" >> "$CSS"
        fi
    done
fi

# 3. Reiniciar nm-applet
pkill -x nm-applet || true
sleep 1

# Entorno de sesion
export WAYLAND_DISPLAY=wayland-1
export DISPLAY=:1
export XDG_RUNTIME_DIR=/run/user/1000
export DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus

nohup nm-applet --indicator >/dev/null 2>&1 &

echo "✅ Sincronización de fuerza bruta completada (BG=$BG, ACCENT=$ACCENT)"
