#!/usr/bin/env bash

# sddm-auto-sync-local: Sincronizador de SDDM con privilegios
# Este script actualiza el wallpaper y los colores de SDDM Astronaut.

set -e

# Rutas
SDDM_THEME_DIR="/usr/share/sddm/themes/sddm-astronaut-theme"
THEME_CONFIG="$SDDM_THEME_DIR/theme.conf"
BACKGROUNDS_DIR="$SDDM_THEME_DIR/Backgrounds"

# Detectar el usuario real y su HOME
if [ -n "$SUDO_USER" ]; then
    REAL_USER="$SUDO_USER"
    REAL_HOME=$(getent passwd "$SUDO_USER" | cut -d: -f6)
elif [ -n "$PKEXEC_UID" ]; then
    REAL_USER=$(getent passwd "$PKEXEC_UID" | cut -d: -f1)
    REAL_HOME=$(getent passwd "$PKEXEC_UID" | cut -d: -f6)
else
    REAL_USER=$(whoami)
    REAL_HOME="$HOME"
fi

CURRENT_WP_CACHE="$REAL_HOME/.cache/current-wallpaper"
PYWAL_SH="$REAL_HOME/.cache/wal/colors.sh"

# Verificar que somos root
if [ "$EUID" -ne 0 ]; then
    echo "Este script debe ejecutarse como root"
    exit 1
fi

# 1. Obtener el wallpaper actual
if [ -f "$CURRENT_WP_CACHE" ]; then
    CURRENT_WP=$(cat "$CURRENT_WP_CACHE")
elif [ -f "$REAL_HOME/.cache/wal/wal" ]; then
    CURRENT_WP=$(cat "$REAL_HOME/.cache/wal/wal")
else
    # Fallback definitivo: Usar el fondo por defecto del tema
    CURRENT_WP="$SDDM_THEME_DIR/Backgrounds/current_wallpaper.jpg"
    echo "No se encontrĂł cache de wallpaper. Usando fondo por defecto: $CURRENT_WP"
fi

# Si el wallpaper detectado no existe, usar el del tema como Ăşltimo recurso
if [ ! -f "$CURRENT_WP" ]; then
    CURRENT_WP="$SDDM_THEME_DIR/Backgrounds/current_wallpaper.jpg"
    echo "El archivo de wallpaper no existe. Usando fondo del tema."
fi

echo "Sincronizando wallpaper: $(basename "$CURRENT_WP")"

# 2. Copiar y convertir wallpaper si es necesario
# SDDM prefiere JPG
TARGET_WP="$BACKGROUNDS_DIR/current_wallpaper.jpg"
if [[ "$CURRENT_WP" == *.gif ]]; then
    magick "$CURRENT_WP[0]" -quality 90 "$TARGET_WP"
else
    cp -f "$CURRENT_WP" "$TARGET_WP"
fi
chmod 644 "$TARGET_WP"

# 3. Sincronizar colores de Pywal
PYWAL_SH="$REAL_HOME/.cache/wal/colors.sh"
if [ -f "$PYWAL_SH" ]; then
    # Leer colores sin importar el entorno
    background=$(grep '^background=' "$PYWAL_SH" | cut -d"'" -f2)
    foreground=$(grep '^foreground=' "$PYWAL_SH" | cut -d"'" -f2)
    color4=$(grep '^color4=' "$PYWAL_SH" | cut -d"'" -f2)
    color8=$(grep '^color8=' "$PYWAL_SH" | cut -d"'" -f2)
    color1=$(grep '^color1=' "$PYWAL_SH" | cut -d"'" -f2)

    echo "Aplicando colores de Pywal a SDDM..."
    
    sed -i "s|^Background=.*|Background=\"Backgrounds/current_wallpaper.jpg\"|" "$THEME_CONFIG"
    sed -i "s|^HighlightColor=.*|HighlightColor=\"$color4\"|" "$THEME_CONFIG"
    sed -i "s|^BackgroundColor=.*|BackgroundColor=\"$background\"|" "$THEME_CONFIG"
    sed -i "s|^TextColor=.*|TextColor=\"$foreground\"|" "$THEME_CONFIG"
    sed -i "s|^PlaceholderColor=.*|PlaceholderColor=\"$color8\"|" "$THEME_CONFIG"
    sed -i "s|^SystemButtonsIconColor=.*|SystemButtonsIconColor=\"$color1\"|" "$THEME_CONFIG"
    
    echo "SDDM actualizado correctamente."
else
    echo "No se encontraron colores de Pywal, solo se actualizĂł el wallpaper."
    # Asegurar que la ruta del background sea correcta incluso sin pywal
    sed -i "s|^Background=.*|Background=\"Backgrounds/current_wallpaper.jpg\"|" "$THEME_CONFIG"
fi
