#!/bin/bash
# Lanza una instancia de rust-dock por cada monitor conectado

RUST_DOCK="/home/rhythmcreative/.local/bin/rust-dock"
STATE_FILE="/tmp/rust-dock-visible"

monitors=$(hyprctl monitors -j 2>/dev/null | jq -r '.[].name')

if [ -z "$monitors" ]; then
    "$RUST_DOCK" &
else
    while IFS= read -r monitor; do
        "$RUST_DOCK" -o "$monitor" &
    done <<< "$monitors"
fi

# Marcar rust-dock como visible al arrancar
touch "$STATE_FILE"
