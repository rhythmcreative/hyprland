#!/bin/bash

# Script adaptativo para rofi que detecta monitores automáticamente
# Soporta: drun, run, window

MODE=${1:-drun}

# Configuración de tema por defecto
THEME="~/.config/rofi/onedark.rasi"

# Verificar si el tema existe
if [ ! -f "$HOME/.config/rofi/onedark.rasi" ]; then
    # Fallback a tema por defecto del sistema
    THEME=""
fi

# Obtener información de monitores
get_active_monitor() {
    if command -v hyprctl &> /dev/null; then
        # Hyprland
        hyprctl monitors -j | jq -r '.[] | select(.focused == true) | .name'
    elif command -v xrandr &> /dev/null; then
        # X11
        xrandr --listmonitors | grep -E '^\s*[0-9]+:.*\*' | awk '{print $4}' | head -1
    else
        echo "primary"
    fi
}

# Obtener configuración de monitor
ACTIVE_MONITOR=$(get_active_monitor)
MONITOR_COUNT=$(xrandr --listmonitors 2>/dev/null | tail -n +2 | wc -l || echo 1)

# Configurar argumentos de rofi según el modo
WALLPAPER_MODI="wallpapers:$HOME/.local/bin/rofi-wallpaper-mode"

case "$MODE" in
    "drun")
        ROFI_ARGS="-show drun -modi drun,$WALLPAPER_MODI"
        ;;
    "run")
        ROFI_ARGS="-show run -modi run,$WALLPAPER_MODI"
        ;;
    "window")
        ROFI_ARGS="-show window -modi window,$WALLPAPER_MODI"
        ;;
    *)
        ROFI_ARGS="-show $MODE -modi $MODE,$WALLPAPER_MODI"
        ;;
esac

# Añadir tema si está disponible
if [ -n "$THEME" ]; then
    ROFI_ARGS="$ROFI_ARGS -theme $THEME"
fi

# Ocultar rust-dock mientras rofi está abierto (solo si está visible en layers)
_rust_dock_was_running=false
_rust_dock_pids=$(pgrep -x rust-dock 2>/dev/null | paste -sd '|')
if [ -n "$_rust_dock_pids" ] && hyprctl layers 2>/dev/null | grep -qE "pid: ($_rust_dock_pids)"; then
    _rust_dock_was_running=true
    pkill -SIGUSR1 rust-dock 2>/dev/null || true
fi

# Configuración para múltiples monitores
if [ "$MONITOR_COUNT" -gt 1 ] && command -v hyprctl &> /dev/null; then
    # En Hyprland, rofi aparecerá en el monitor activo automáticamente
    rofi $ROFI_ARGS
else
    # Monitor único o sistema sin Hyprland
    rofi $ROFI_ARGS
fi

# Restaurar rust-dock al estado original (toggle inverso)
if [ "$_rust_dock_was_running" = true ]; then
    pkill -SIGUSR1 rust-dock 2>/dev/null || true
fi
