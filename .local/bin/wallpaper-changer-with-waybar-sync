#!/bin/bash

# Wallpaper changer mejorado CON sincronización automática de waybar-pywal
# Combina el selector de wallpapers con la sincronización completa de Waybar
# Ejecutado por: Super + Shift + W

set -euo pipefail

WALLPAPER_DIR="$HOME/Pictures/Wallpapers"
CACHE_DIR="$HOME/.cache/wallpaper-previews"
TEMP_FILE="/tmp/rofi_wallpaper_$$"
LOG_FILE="$HOME/.cache/wallpaper-changer-with-waybar.log"
LOCK_FILE="/tmp/wallpaper-waybar-change.lock"

# Crear directorios necesarios
mkdir -p "$CACHE_DIR"
mkdir -p "$(dirname "$LOG_FILE")"

# Función de logging
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
    echo "$1" >&2
}

# Función para ocultar Waybar de forma temporal y segura
hide_waybar() {
    local waybar_pids=$(pgrep -x waybar)
    if [[ -n "$waybar_pids" ]]; then
        # Usar SIGUSR1 para toggle (ocultar/mostrar)
        kill -USR1 $waybar_pids 2>/dev/null && log "📱 Waybar ocultado temporalmente" || true
    fi
}

# Función para mostrar Waybar de forma segura
show_waybar() {
    local waybar_pids=$(pgrep -x waybar)
    if [[ -n "$waybar_pids" ]]; then
        # Verificar si waybar está oculto y mostrarlo
        kill -USR1 $waybar_pids 2>/dev/null && log "📱 Waybar mostrado nuevamente" || true
        # Dar un momento para que se procese la señal
        sleep 0.5
    else
        log "🚀 Waybar no estaba corriendo, iniciándolo..."
        waybar > /dev/null 2>&1 &
        sleep 1
        # Verificar que se inició correctamente
        if pgrep -x waybar > /dev/null; then
            log "✅ Waybar iniciado correctamente"
        else
            log "❌ ERROR: No se pudo iniciar waybar en show_waybar"
        fi
    fi
}

# Función para recargar Waybar CSS
reload_waybar_css() {
    pkill -SIGUSR1 waybar 2>/dev/null || true
}

# Función de limpieza (SIN REINICIAR WAYBAR)
cleanup() {
    local exit_code=$?
    # NO restaurar Waybar al salir para evitar múltiples reinicios
    # show_waybar
    rm -f "$TEMP_FILE"* "$LOCK_FILE" 2>/dev/null || true
    if [[ $exit_code -ne 0 ]]; then
        log "ERROR: Script terminó con código $exit_code"
    fi
}

trap cleanup EXIT INT TERM

# Verificar si ya hay un cambio en progreso
if [[ -f "$LOCK_FILE" ]]; then
    lock_pid=$(cat "$LOCK_FILE" 2>/dev/null)
    if [[ -n "$lock_pid" ]] && kill -0 "$lock_pid" 2>/dev/null; then
        log "⏳ Cambio de wallpaper+waybar ya en progreso (PID: $lock_pid)"
        exit 0
    else
        rm -f "$LOCK_FILE"
    fi
fi

# Crear archivo de bloqueo
echo $$ > "$LOCK_FILE"

log "=== Iniciando selector de wallpapers con sincronización waybar-pywal ==="

# Función para aplicar wallpaper CON sincronización completa
apply_wallpaper_with_waybar_sync() {
    local wallpaper_file="$1"
    
    log "🖼️ Aplicando wallpaper: $wallpaper_file"
    
    # Aplicar wallpaper con awww
    if awww img "$wallpaper_file" --transition-type grow --transition-pos "0.9,0.1" --transition-duration 1.5; then
        log "✅ Wallpaper aplicado con awww"
    else
        log "❌ Error al aplicar wallpaper con awww"
        return 1
    fi
    
    # Guardar wallpaper actual
    echo "$wallpaper_file" > "$HOME/.cache/current-wallpaper"
    
    # Ejecutar sincronización centralizada
    if [ -x "$HOME/.local/bin/pywal-wallpaper-sync" ]; then
        log "🎨 Iniciando sincronización centralizada..."
        "$HOME/.local/bin/pywal-wallpaper-sync" "$wallpaper_file"
        log "✅ Sistema sincronizado"
    else
        # Fallback básico
        wal -i "$wallpaper_file" -n -q
        hyprctl reload
    fi
    
    notify-send "🎨 Sistema Sincronizado" "$(basename "$wallpaper_file")" -i "$wallpaper_file" -t 3000 2>/dev/null || true
}

# Verificar directorio de wallpapers
if [[ ! -d "$WALLPAPER_DIR" ]]; then
    log "ERROR: Directorio $WALLPAPER_DIR no encontrado"
    notify-send "❌ Error" "Directorio de wallpapers no encontrado" -u critical
    exit 1
fi

# Verificar awww
if ! command -v awww &>/dev/null; then
    log "ERROR: awww no está instalado"
    notify-send "❌ Error" "awww no está instalado" -u critical
    exit 1
fi

# Verificar e iniciar awww-daemon si es necesario
if ! pgrep -x "awww-daemon" >/dev/null; then
    log "🚀 Iniciando awww-daemon..."
    notify-send "🔄 Iniciando awww..." "Preparando sistema de wallpapers"
    awww-daemon --format xrgb &
    sleep 3
fi

# Buscar imágenes
log "🔍 Buscando imágenes en $WALLPAPER_DIR"
cd "$WALLPAPER_DIR" || { log "ERROR: No se pudo acceder a $WALLPAPER_DIR"; exit 1; }

mapfile -t images < <(find . -maxdepth 1 -type f \( -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" -o -iname "*.gif" -o -iname "*.webp" -o -iname "*.bmp" \) | sed 's|^./||' | sort)

if [[ ${#images[@]} -eq 0 ]]; then
    log "ERROR: No se encontraron imágenes"
    notify-send "❌ Error" "No se encontraron imágenes en el directorio" -u critical
    exit 1
fi

log "📁 Encontradas ${#images[@]} imágenes"

# Crear archivo temporal para rofi
> "$TEMP_FILE"

# Procesar cada imagen para crear previews
for img in "${images[@]}"; do
    [[ ! -f "$img" ]] && continue
    
    clean_name="${img%.*}"
    preview_file="$CACHE_DIR/preview_${clean_name}.png"
    
    # Crear preview si no existe
    if [[ ! -f "$preview_file" ]]; then
        if [[ "$img" == *.gif ]]; then
            convert "$img[0]" -resize "200x150^" -gravity center -extent "200x150" "$preview_file" 2>/dev/null || continue
        else
            convert "$img" -resize "200x150^" -gravity center -extent "200x150" "$preview_file" 2>/dev/null || continue
        fi
    fi
    
    # Agregar entrada a rofi
    if [[ -f "$preview_file" ]]; then
        echo -e "$clean_name\\0icon\\x1f$preview_file" >> "$TEMP_FILE"
    else
        echo "$clean_name" >> "$TEMP_FILE"
    fi
done

# Verificar que tenemos entradas
if [[ ! -s "$TEMP_FILE" ]]; then
    log "ERROR: No se pudieron procesar las imágenes"
    notify-send "❌ Error" "No se pudieron procesar las imágenes" -u critical
    exit 1
fi

log "🎭 Mostrando selector de wallpapers con sincronización waybar..."

# Ocultar Waybar antes de mostrar Rofi
hide_waybar
log "📱 Waybar ocultado para mostrar selector"

# Ejecutar rofi con tema apropiado
selected=$(rofi -dmenu -i \
    -p "🖼️ Wallpaper + Waybar Sync" \
    -show-icons \
    -theme "$HOME/HyprNova/.config/rofi/themes/wallpaper-select.rasi" \
    < "$TEMP_FILE")

# Si no se selecciónó nada, mostrar waybar y salir
if [[ -z "$selected" ]]; then
    log "ℹ️ No se selecciónó ningún wallpaper"
    show_waybar
    exit 0
fi

log "✅ Seleccionado: $selected"

# Buscar el archivo correspondiente
selected_file=""
for img in "${images[@]}"; do
    if [[ "${img%.*}" == "$selected" ]]; then
        selected_file="$WALLPAPER_DIR/$img"
        break
    fi
done

# Verificar archivo seleccionado
if [[ -z "$selected_file" ]] || [[ ! -f "$selected_file" ]]; then
    log "ERROR: Archivo no encontrado: $selected"
    notify-send "❌ Error" "Archivo no encontrado" -u critical
    exit 1
fi

# Aplicar wallpaper CON sincronización completa de waybar
apply_wallpaper_with_waybar_sync "$selected_file"

# NO hacer verificación final para evitar reinicios adicionales
log "✅ Proceso completado - Waybar debería estar funcionando correctamente"

log "🎉 Script completado exitosamente - Wallpaper y Waybar sincronizados"
exit 0
